generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model app_data {
  key        String  @id
  data_json  String?
  updated_at String?
}

model company_profiles {
  id                    String                  @id
  name                  String
  email                 String
  phone                 String?
  address               String?
  gstin                 String?
  pan                   String?
  state                 String?
  bank_name             String?
  bank_branch           String?
  account_no            String?
  ifsc                  String?
  header_image          String?
  footer_image          String?
  signature_image       String?
  template              String?                 @default("minimal")
  quotation_prefix      String?                 @default("QT-")
  invoice_prefix        String?                 @default("INV-")
  challan_prefix        String?                 @default("DC-")
  next_quotation_number Int?                    @default(1)
  next_invoice_number   Int?                    @default(1)
  next_challan_number   Int?                    @default(1)
  enable_gst            Boolean?                @default(true)
  profit_without_gst    Boolean?                @default(true)
  created_at            DateTime                @default(now())
  updated_at            DateTime
  delivery_challans     delivery_challans[]
  invoices              invoices[]
  quotations            quotations[]
  subscription_policies subscription_policies[]
  terms_presets         terms_presets[]
}

model customers {
  id                String              @id
  name              String
  company           String?
  email             String?
  phone             String?
  gstin             String?
  state             String
  billing_address   String?
  shipping_address  String?
  created_at        DateTime            @default(now())
  updated_at        DateTime
  delivery_challans delivery_challans[]
  invoices          invoices[]
  leads             leads[]
  quotations        quotations[]
  reminders         reminders[]
  subscriptions     subscriptions[]
}

model delivery_challan_items {
  id                  Int               @id @default(autoincrement())
  delivery_challan_id String
  product_name        String
  quantity            Decimal           @default(1) @db.Decimal(15, 4)
  hsn_code            String?
  description         String?
  delivery_challans   delivery_challans @relation(fields: [delivery_challan_id], references: [id], onDelete: Cascade)
}

model delivery_challans {
  id                     String                   @id
  challan_no             String                   @unique
  date                   DateTime                 @db.Date
  customer_id            String
  vehicle_no             String?
  transporter            String?
  lr_number              String?
  dispatch_address       String?
  status                 String?                  @default("Dispatched")
  notes                  String?
  company_id             String?
  created_at             DateTime                 @default(now())
  updated_at             DateTime
  delivery_challan_items delivery_challan_items[]
  company_profiles       company_profiles?        @relation(fields: [company_id], references: [id])
  customers              customers                @relation(fields: [customer_id], references: [id])
}

model inventory_items {
  id                    String           @id
  sku                   String           @unique
  product_name          String
  category              String?
  quantity              Decimal          @default(0.0000) @db.Decimal(15, 4)
  min_quantity          Decimal          @default(0.0000) @db.Decimal(15, 4)
  purchase_from         String?
  unit_price            Decimal          @default(0.00) @db.Decimal(15, 2)
  latest_purchase_price Decimal?         @db.Decimal(15, 2)
  last_updated          DateTime         @default(now())
  created_at            DateTime         @default(now())
  products              products         @relation(fields: [sku], references: [sku])
  inventory_logs        inventory_logs[]
}

model inventory_logs {
  id                String          @id
  inventory_item_id String
  date              DateTime        @default(now())
  type              String
  quantity          Decimal         @db.Decimal(15, 4)
  reason            String?
  prev_qty          Decimal         @db.Decimal(15, 4)
  new_qty           Decimal         @db.Decimal(15, 4)
  supplier_name     String?
  customer_name     String?
  inventory_items   inventory_items @relation(fields: [inventory_item_id], references: [id], onDelete: Cascade)
}

model invoice_items {
  id               Int       @id @default(autoincrement())
  invoice_id       String
  product_id       String?
  product_name     String
  description      String?
  hsn_code         String?
  quantity         Decimal   @default(1) @db.Decimal(15, 4)
  rate             Decimal   @default(0.00) @db.Decimal(15, 2)
  discount_percent Decimal?  @default(0.00) @db.Decimal(5, 2)
  gst_percent      Decimal?  @default(18.00) @db.Decimal(5, 2)
  invoices         invoices  @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  products         products? @relation(fields: [product_id], references: [id])
}

model invoices {
  id                  String            @id
  invoice_no          String            @unique
  quotation_no        String?
  date                DateTime          @db.Date
  due_date            DateTime?         @db.Date
  customer_id         String
  subject             String?
  subtotal            Decimal           @default(0.00) @db.Decimal(15, 2)
  discount_total      Decimal           @default(0.00) @db.Decimal(15, 2)
  cgst_total          Decimal           @default(0.00) @db.Decimal(15, 2)
  sgst_total          Decimal           @default(0.00) @db.Decimal(15, 2)
  igst_total          Decimal           @default(0.00) @db.Decimal(15, 2)
  grand_total         Decimal           @default(0.00) @db.Decimal(15, 2)
  status              String?           @default("Unpaid")
  terms               String?
  company_id          String?
  terms_preset_id     String?
  freight             Decimal?          @default(0.00) @db.Decimal(15, 2)
  additional_discount Decimal?          @default(0.00) @db.Decimal(15, 2)
  customer_signature  String?
  customer_signed_at  DateTime?
  created_at          DateTime          @default(now())
  updated_at          DateTime
  invoice_items       invoice_items[]
  company_profiles    company_profiles? @relation(fields: [company_id], references: [id])
  customers           customers         @relation(fields: [customer_id], references: [id])
  quotations          quotations?       @relation(fields: [quotation_no], references: [quotation_no])
  terms_presets       terms_presets?    @relation(fields: [terms_preset_id], references: [id])
}

model leads {
  id                String     @id
  customer_id       String?
  name              String
  company           String?
  email             String?
  phone             String?
  value             Decimal    @default(0.00) @db.Decimal(15, 2)
  status            String?    @default("New")
  source            String?
  notes             String?
  date              DateTime?  @db.Date
  conversion_status String?    @default("Cold")
  created_at        DateTime   @default(now())
  updated_at        DateTime
  customers         customers? @relation(fields: [customer_id], references: [id])
}

model products {
  id                  String            @id
  name                String
  sku                 String            @unique
  rate                Decimal           @default(0.00) @db.Decimal(15, 2)
  gst_rate            Decimal           @default(18.00) @db.Decimal(5, 2)
  hsn_code            String?
  description         String?
  item_type           String?           @default("Product")
  mrp                 Decimal?          @db.Decimal(15, 2)
  last_purchase_price Decimal?          @db.Decimal(15, 2)
  sell_price          Decimal?          @db.Decimal(15, 2)
  created_at          DateTime          @default(now())
  updated_at          DateTime
  inventory_items     inventory_items?
  invoice_items       invoice_items[]
  quotation_items     quotation_items[]
}

model quotation_items {
  id               Int        @id @default(autoincrement())
  quotation_id     String
  product_id       String?
  product_name     String
  description      String?
  hsn_code         String?
  quantity         Decimal    @default(1) @db.Decimal(15, 4)
  rate             Decimal    @default(0.00) @db.Decimal(15, 2)
  discount_percent Decimal?   @default(0.00) @db.Decimal(5, 2)
  gst_percent      Decimal?   @default(18.00) @db.Decimal(5, 2)
  products         products?  @relation(fields: [product_id], references: [id])
  quotations       quotations @relation(fields: [quotation_id], references: [id], onDelete: Cascade)
}

model quotations {
  id                                                        String            @id
  quotation_no                                              String            @unique
  date                                                      DateTime          @db.Date
  valid_until                                               DateTime?         @db.Date
  customer_id                                               String
  subject                                                   String?
  subtotal                                                  Decimal           @default(0.00) @db.Decimal(15, 2)
  discount_total                                            Decimal           @default(0.00) @db.Decimal(15, 2)
  cgst_total                                                Decimal           @default(0.00) @db.Decimal(15, 2)
  sgst_total                                                Decimal           @default(0.00) @db.Decimal(15, 2)
  igst_total                                                Decimal           @default(0.00) @db.Decimal(15, 2)
  grand_total                                               Decimal           @default(0.00) @db.Decimal(15, 2)
  status                                                    String?           @default("Draft")
  terms                                                     String?
  company_id                                                String?
  terms_preset_id                                           String?
  freight                                                   Decimal?          @default(0.00) @db.Decimal(15, 2)
  additional_discount                                       Decimal?          @default(0.00) @db.Decimal(15, 2)
  customer_signature                                        String?
  customer_signed_at                                        DateTime?
  revision_of_id                                            String?
  original_quote_id                                         String?
  revision_number                                           Int?              @default(0)
  created_at                                                DateTime          @default(now())
  updated_at                                                DateTime
  invoices                                                  invoices[]
  quotation_items                                           quotation_items[]
  company_profiles                                          company_profiles? @relation(fields: [company_id], references: [id])
  customers                                                 customers         @relation(fields: [customer_id], references: [id])
  quotations_quotations_original_quote_idToquotations       quotations?       @relation("quotations_original_quote_idToquotations", fields: [original_quote_id], references: [id])
  other_quotations_quotations_original_quote_idToquotations quotations[]      @relation("quotations_original_quote_idToquotations")
  quotations_quotations_revision_of_idToquotations          quotations?       @relation("quotations_revision_of_idToquotations", fields: [revision_of_id], references: [id])
  other_quotations_quotations_revision_of_idToquotations    quotations[]      @relation("quotations_revision_of_idToquotations")
  terms_presets                                             terms_presets?    @relation(fields: [terms_preset_id], references: [id])
}

model reminders {
  id              String         @id
  title           String
  description     String?
  due_date        DateTime
  status          String?        @default("Pending")
  priority        String?        @default("Medium")
  related_to      String?
  subscription_id String?
  customer_id     String?
  created_at      DateTime       @default(now())
  updated_at      DateTime
  customers       customers?     @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  subscriptions   subscriptions? @relation(fields: [subscription_id], references: [id], onDelete: Cascade)
}

model subscription_policies {
  id                     String            @id
  company_profile_id     String?
  days_before_renewal    Int               @default(7)
  email_subject_template String?
  email_body_template    String?
  is_active              Boolean?          @default(true)
  created_at             DateTime          @default(now())
  company_profiles       company_profiles? @relation(fields: [company_profile_id], references: [id], onDelete: Cascade)
}

model subscriptions {
  id                String      @id
  customer_id       String
  service_name      String
  amount            Decimal     @default(0.00) @db.Decimal(15, 2)
  billing_cycle     String
  start_date        DateTime    @db.Date
  next_renewal_date DateTime    @db.Date
  status            String?     @default("Active")
  description       String?
  created_at        DateTime    @default(now())
  updated_at        DateTime
  reminders         reminders[]
  customers         customers   @relation(fields: [customer_id], references: [id], onDelete: Cascade)
}

model terms_presets {
  id                 String            @id
  company_profile_id String?
  title              String
  content            String
  created_at         DateTime          @default(now())
  invoices           invoices[]
  quotations         quotations[]
  company_profiles   company_profiles? @relation(fields: [company_profile_id], references: [id], onDelete: Cascade)
}

model user_profiles {
  id         String   @id
  name       String?
  email      String?  @unique
  role       String?
  password   String?
  is_active  Boolean? @default(true)
  rights     String?
  created_at String?
}

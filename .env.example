# .env.example
# Direct PostgreSQL connection URLs for your database (e.g. Neon DB, Vercel Postgres, AWS RDS, etc.)
DATABASE_URL=postgres://username:password@host:5432/database?sslmode=require
DATABASE_URL_UNPOOLED=postgres://username:password@host:5432/database?sslmode=require
POSTGRES_URL=postgres://username:password@host:5432/database?sslmode=require

# Gemini API Key for AI-powered feature generation
GEMINI_API_KEY=

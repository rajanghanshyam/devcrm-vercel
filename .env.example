# .env.example
# Direct PostgreSQL connection URLs for your database (e.g. Prisma DB, Vercel Postgres, AWS RDS, etc.)
DATABASE_URL=postgres://username:password@host:5432/database?sslmode=require
POSTGRES_URL=postgres://username:password@host:5432/database?sslmode=require
PRISMA_DATABASE_URL=postgres://username:password@host:5432/database?sslmode=require

# Gemini API Key for AI-powered feature generation
GEMINI_API_KEY=
